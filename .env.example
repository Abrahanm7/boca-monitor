# URL principal
MATCHES_URL=https://bocasocios.bocajuniors.com.ar/matches

# Intervalo de chequeo en milisegundos
CHECK_INTERVAL_MS=2500

# Timeout general de espera
DEFAULT_TIMEOUT_MS=15000

# Carpeta de sesión persistente de Playwright
USER_DATA_DIR=./user_data

# Si querés filtrar por un texto específico del partido, ponelo acá.
# Si lo dejás vacío, el bot intentará entrar al único partido habilitado.
TARGET_MATCH_TEXT=

# --- WhatsApp Cloud API (opcional) ---
WHATSAPP_ENABLED=false
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TO=54911XXXXXXXX

# --- Telegram (opcional) ---
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Headless: false = ver navegador; true = oculto
HEADLESS=false

# Sacar screenshot cuando entra al partido
SCREENSHOT_ON_ENTER=true

# Reproducir sonido local al entrar al partido
SOUND_ALERT=true
